import os

config.my_src_root = r'@CMAKE_CURRENT_SOURCE_DIR@'
config.my_obj_root = r'@CMAKE_CURRENT_BINARY_DIR@'

# Needed for clang, llvm-dis, etc.
config.environment['PATH'] = os.pathsep.join(["@LLVM_TOOLS_BINARY_DIR@",
                                              config.environment['PATH']])

# Needed for Luthier binaries
config.environment['PATH'] = os.pathsep.join(["@CMAKE_BINARY_DIR@/bin",
                                              config.environment['PATH']])

lit_config.load_config(
      config, os.path.join(config.my_src_root, "lit.cfg.py"))


plugin_path = os.path.join("@CMAKE_BINARY_DIR@/lib", "LuthierToolCodeGenPlugin.so")
config.substitutions.append(('%luthier_tool_code_gen_plugin', f"-load-pass-plugin={plugin_path}"))

tool_ir_compilation_plugin_path = os.path.join("@CMAKE_BINARY_DIR@/lib",
                                 "LuthierToolIRCompilationPlugin.so")
config.substitutions.append(
    ('%luthier_tool_ir_compilation_plugin_path', f"-load-pass-plugin={tool_ir_compilation_plugin_path}"))

tool_cxx_compilation_plugin_path = os.path.join("@CMAKE_BINARY_DIR@/lib",
                                       "LuthierToolCXXCompilationPlugin.so")
config.substitutions.append(
    ('%luthier_tool_cxx_compilation_plugin_path', tool_cxx_compilation_plugin_path))

config.substitutions.append(('%clangxx', "@LLVM_TOOLS_BINARY_DIR@/clang++"))

config.substitutions.append(('%luthier_split_test',
    os.path.join("@CMAKE_BINARY_DIR@/bin", "luthier-split-test")))
